# ── API Keys (required) ──────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=                          # Optional: fallback model

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Model Configuration ─────────────────────────────────────────────────────
PRIMARY_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gemini-2.0-flash
MODEL_TEMPERATURE=0.0
MODEL_MAX_RETRIES=2
MODEL_TIMEOUT_SECONDS=60

# ── Extraction Settings ─────────────────────────────────────────────────────
PDF_RENDER_DPI=200
MAX_FILE_SIZE_MB=50
CONFIDENCE_HIGH_THRESHOLD=0.85
CONFIDENCE_LOW_THRESHOLD=0.60
ENABLE_OCR_VALIDATION=true
ENABLE_IMAGE_ENHANCEMENT=true

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docmind

